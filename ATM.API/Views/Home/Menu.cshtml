@{
    ViewData["Title"] = "Головне меню";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 bg-dark text-white rounded-4">
                <div class="card-header border-secondary py-3 bg-gradient">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 text-info font-monospace">Банкомат</h4>
                        <span id="cardDisplay" class="badge bg-secondary px-3 py-2">Завантаження...</span>
                    </div>
                </div>

                <div class="card-body p-5">
                    <div class="row g-4">
                        <div class="col-md-6">
                            <button class="btn btn-outline-info w-100 py-4 h-100 transition-btn" onclick="fetchBalance()">
                                <i class="bi bi-wallet2 display-4 d-block mb-2"></i>
                                <span class="fs-5 fw-bold">Перегляд балансу</span>
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-outline-success w-100 py-4 h-100 transition-btn" onclick="window.location.href='/Home/Deposit'">
                                <i class="bi bi-cash-stack display-4 d-block mb-2"></i>
                                <span class="fs-5 fw-bold">Поповнити рахунок</span>
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-outline-warning w-100 py-4 h-100 transition-btn" onclick="window.location.href='/Home/Withdraw'">
                                <i class="bi bi-currency-exchange display-4 d-block mb-2"></i>
                                <span class="fs-5 fw-bold">Зняти готівку</span>
                            </button>
                        </div>
                        <div class="col-md-6">
                            <button class="btn btn-outline-light w-100 py-4 h-100 transition-btn" onclick="window.location.href='/Home/History'">
                                <i class="bi bi-clock-history display-4 d-block mb-2"></i>
                                <span class="fs-5 fw-bold">Історія операцій</span>
                            </button>
                        </div>
                    </div>
                </div>

                <div class="card-footer border-0 p-4 text-center">
                    <button class="btn btn-danger btn-lg px-5 shadow" onclick="logout()">
                        <i class="bi bi-box-arrow-left me-2"></i> Завершити роботу
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="balanceModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content bg-dark text-white border-info shadow-lg">
            <div class="modal-header border-info">
                <h5 class="modal-title text-info">Поточний баланс</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body text-center py-5">
                <h2 class="text-secondary mb-0">Доступно:</h2>
                <h1 id="balanceDisplay" class="display-1 fw-bold text-info">0.00</h1>
                <h3 class="text-secondary">USD</h3>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            const cardNum = sessionStorage.getItem('atm_cardNumber');
            if (cardNum) {
                document.getElementById('cardDisplay').textContent = `CARD: **** ${cardNum.slice(-4)}`;
            } else {
                window.location.href = '/Home/Index'; 
            }
        });

        async function fetchBalance() {
            const cardId = sessionStorage.getItem('atm_cardId');
            const pin = sessionStorage.getItem('atm_pin');

            try {
                const response = await fetch('/api/atm/balance', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ cardId: cardId, pin: pin })
                });

                const data = await response.json();
                if (response.ok) {
                    document.getElementById('balanceDisplay').textContent = data.balance.toFixed(2);
                    new bootstrap.Modal(document.getElementById('balanceModal')).show();
                } else {
                    alert("Помилка: " + data.message);
                }
            } catch (err) {
                alert("Помилка зв'язку з сервером");
            }
        }

        function logout() {
            sessionStorage.clear();
            window.location.href = '/Home/Index';
        }
    </script>
}