@{
    ViewData["Title"] = "Історія операцій";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0 bg-dark text-white rounded-4">
                <div class="card-header border-secondary py-3 bg-gradient">
                    <div class="d-flex justify-content-between align-items-center">
                        <h4 class="mb-0 text-info"><i class="bi bi-clock-history"></i> Останні операції</h4>
                        <button class="btn btn-sm btn-outline-secondary" onclick="location.href='/Home/Menu'">
                            <i class="bi bi-arrow-left"></i> Назад до меню
                        </button>
                    </div>
                </div>
                <div class="card-body p-0">
                    <div class="table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-dark table-hover table-striped mb-0">
                            <thead class="position-sticky top-0 bg-dark" style="z-index: 1;">
                                <tr>
                                    <th class="ps-4 text-secondary">Дата та час</th>
                                    <th class="text-secondary">Тип операції</th>
                                    <th class="text-end pe-4 text-secondary">Сума</th>
                                </tr>
                            </thead>
                            <tbody id="historyTableBody">
                                <tr>
                                    <td colspan="3" class="text-center py-4 text-secondary">
                                        <div class="spinner-border text-info" role="status"></div>
                                        <p class="mt-2 mb-0">Завантаження історії...</p>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', loadHistory);

        async function loadHistory() {
            const cardId = sessionStorage.getItem('atm_cardId');
            const tbody = document.getElementById('historyTableBody');

            if (!cardId) {
                window.location.href = '/Home/Index';
                return;
            }

            try {
                const response = await fetch(`/api/atm/history/${cardId}`);

                if (response.ok) {
                    const transactions = await response.json();

                    if (transactions.length === 0) {
                        tbody.innerHTML = `<tr><td colspan="3" class="text-center py-4 text-secondary">Історія операцій порожня.</td></tr>`;
                        return;
                    }

                    tbody.innerHTML = transactions.map(tr => {

                        const isIncome = tr.type === 'Deposit' || tr.type === 'Поповнення' || tr.amount > 0;
                        const sign = isIncome ? '+' : '-';
                        const colorClass = isIncome ? 'text-success' : 'text-danger';
                        const badgeClass = isIncome ? 'bg-success' : 'bg-danger';

                        const typeName = translateType(tr.type);

                        return `
                            <tr>
                                <td class="ps-4 align-middle font-monospace small">${tr.date}</td>
                                <td class="align-middle">
                                    <span class="badge ${badgeClass} bg-opacity-25 ${colorClass} border border-${isIncome ? 'success' : 'danger'}">
                                        ${typeName}
                                    </span>
                                </td>
                                <td class="text-end pe-4 align-middle fs-5 font-monospace fw-bold ${colorClass}">
                                    ${sign}${Math.abs(tr.amount).toFixed(2)} USD
                                </td>
                            </tr>
                        `;
                    }).join('');
                } else {
                    tbody.innerHTML = `<tr><td colspan="3" class="text-center py-4 text-danger">Не вдалося завантажити історію.</td></tr>`;
                }
            } catch (error) {
                tbody.innerHTML = `<tr><td colspan="3" class="text-center py-4 text-danger">Помилка з'єднання з сервером.</td></tr>`;
            }
        }

        function translateType(type) {
            const types = {
                'Deposit': 'Поповнення',
                'Withdraw': 'Зняття готівки',
                'Transfer': 'Переказ'
            };
            return types[type] || type; 
        }
    </script>
}